{
  "name": "metacode-server",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "test:e2e": "dotenv -e .env -- vitest run",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.0.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-mariadb": "~7.7.0",
    "@prisma/client": "~7.7.0",
    "@sapphire/snowflake": "^3.5.5",
    "@scalar/fastify-api-reference": "^1.52.3",
    "@trpc/server": "npm:@trpc/server",
    "ali-oss": "^6.23.0",
    "axios": "^1.7.2",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.19",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "fs-extra": "^11.2.0",
    "mariadb": "^3.4.5",
    "minio": "^8.0.6",
    "nanoid": "^3.3.7",
    "superjson": "^2.2.2",
    "trpc-to-openapi": "^3.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@trpc/client": "^11.9.0",
    "@types/ali-oss": "^6.23.3",
    "@types/crypto-js": "^4.2.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "~7.7.0",
    "tsx": "^4.19.3",
    "typescript": "6.0.3",
    "vitest": "^4.0.18"
  }
}
