generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "mysql"
}

enum ClientTypeEnum {
  PC
  H5
}

enum AppItemCategory {
  DATA
  FLOW
  STAT
  BI
  CUSTOM
  THIRD_LINK
}

enum AppItemType {
  ITEM_GROUP
  ITEM
}

enum AppStatus {
  RUNNING
  MAINTENANCE
  NOT_RELEASED
}

enum AppViewCategory {
  COMMON
  USER
}

enum AppViewPlatform {
  PC
  H5
}

enum AppViewScene {
  LIST
  DETAIL
}

enum AppViewType {
  TABLE_VIEW
  CARD_VIEW
  KANBAN_VIEW
  CALENDAR_VIEW
  DESIGNER_VIEW
  GANTT_VIEW
}

model User {
  id                                                     BigInt                @id @default(autoincrement())
  createdAt                                              DateTime?             @map("created_at") @db.DateTime(6)
  avatar                                                 String?               @db.VarChar(255)
  description                                            String?               @db.VarChar(255)
  fullName                                               String?               @map("full_name") @db.VarChar(255)
  gender                                                 Int?                  @db.TinyInt
  leaderIds                                              String?               @map("leader_ids") @db.VarChar(255)
  state                                                  Int                   @db.TinyInt
  username                                               String?               @db.VarChar(255)
  mainJobId                                              BigInt?               @map("main_job_id")
  leaderId                                               BigInt?               @map("leader_id")
  delegateId                                             BigInt?               @map("delegate_id")
  createTime                                             DateTime?             @map("create_time") @db.DateTime(6)
  tenantId                                               String?               @map("tenant_id") @db.VarChar(255)
  accountId                                              BigInt?               @map("account_id")
  appDataShare                                           AppDataShare[]
  appView                                                AppView[]
  authSecret                                             AuthSecret[]
  message                                                Message[]
  messageNotificationMessageNotificationReceiverIdToUser MessageNotification[] @relation("message_notification_receiver_idTouser")
  messageNotificationMessageNotificationSenderIdToUser   MessageNotification[] @relation("message_notification_sender_idTouser")
  organizationOrganizationLeaderIdToUser                 Organization?         @relation("organization_leader_idTouser")
  roleMember                                             RoleMember[]
  spaceInvitation                                        SpaceInvitation[]
  userUserDelegateIdToUser                               User?                 @relation("user_delegate_idTouser", fields: [delegateId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FK25f28xhoa4jw0ucragc1ehfic")
  otherUserUserDelegateIdToUser                          User[]                @relation("user_delegate_idTouser")
  account                                                Account?              @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_nrrhhb0bsexvi8ch6wnon9uog")
  userUserLeaderIdToUser                                 User?                 @relation("user_leader_idTouser", fields: [leaderId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FKjd7op1vctb1hw0m1p0tiht690")
  otherUserUserLeaderIdToUser                            User[]                @relation("user_leader_idTouser")
  organizationUserMainJobIdToOrganization                Organization?         @relation("user_main_job_idToorganization", fields: [mainJobId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FKrcs01m1fnlkhq7fx4nqarpll6")
  userApp                                                UserApp[]
  userOrganization                                       UserOrganization[]

  @@index([delegateId], map: "FKajq3s3dlrtvc7ogfi5y7kn6w2")
  @@index([accountId], map: "FKgf2sfm2i6rsce1dvpdr0bchp6")
  @@index([leaderId], map: "FKjd7op1vctb1hw0m1p0tiht690")
  @@index([mainJobId], map: "FKrcs01m1fnlkhq7fx4nqarpll6")
  @@map("user")
}

model Account {
  id              BigInt            @id @default(autoincrement())
